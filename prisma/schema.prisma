generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String?
  Instagram     String?
  Linkdin       String?
  bio           String?
  createdAt     DateTime     @default(now())
  emailVerified Boolean      @default(false)
  github        String?
  image         String?
  location      String?
  updatedAt     DateTime     @updatedAt
  website       String?
  deletedAt     DateTime?
  isDeleted     Boolean      @default(false)
  accounts      Account[]
  bookMarks     BookMark[]
  comments      Comment[]
  likes         Like[]
  posts         Post[]
  sessions      Session[]
  emailupdates  emailupdate?
  postViews     PostView[]
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  status PostStatus @default(DRAFT)
  postViews   PostView[]
  content     String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String
  ScheduledAt DateTime?
  coverImage  String[]
  publishedAt DateTime?
  visibility  Visibility @default(PUBLIC)
  bookMarks   BookMark[]
  comments    Comment[]
  likes       Like[]
  author      User       @relation(fields: [authorId], references: [id])
  postTags    PostTag[]
}

model PostView {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model PostTag {
  PostId Int
  TagId  Int
  post   Post @relation(fields: [PostId], references: [id])
  tag    Tag  @relation(fields: [TagId], references: [id])

  @@id([PostId, TagId])
}

model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  posts PostTag[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  postId    Int
  author    User     @relation(fields: [authorId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
}

model BookMark {
  id     Int    @id @default(autoincrement())
  userId String
  postId Int
  post   Post   @relation(fields: [postId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    String
  postId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  scope                 String?
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  accountId             String
  createdAt             DateTime  @default(now())
  idToken               String?
  providerId            String
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  updatedAt             DateTime  @updatedAt
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  ipAddress String?
  token     String   @unique
  updatedAt DateTime @updatedAt
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model emailupdate {
  id        String   @id @default(cuid())
  userId    String   @unique
  newEmail  String
  otp       String
  expiredAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}
